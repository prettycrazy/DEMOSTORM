FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=your_app_secret
FEISHU_BITABLE_APP_TOKEN=app_token
FEISHU_PROJECTS_TABLE_ID=tbl_projects
FEISHU_IDEAS_TABLE_ID=tbl_ideas
FEISHU_PROJECTS_TABLE_URL="https://your-subdomain.feishu.cn/wiki/your_app?table=tbl_projects&view=view_projects"
FEISHU_IDEAS_TABLE_URL="https://your-subdomain.feishu.cn/wiki/your_app?table=tbl_ideas&view=view_ideas"
FEISHU_REDIRECT_URI=http://localhost:8002/api/oauth/callback
FEISHU_OAUTH_SCOPE="auth:user.id:read bitable:app base:record:create base:record:read"
FEISHU_GUEST_MODE=false
SESSION_SECRET=replace_with_long_random
